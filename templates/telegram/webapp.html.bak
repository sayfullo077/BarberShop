<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>BarberShop</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
/* ── Reset ─────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

/* ── Design Tokens — Dark (default) ────────────────────── */
:root {
  --gold:    #d19f68;
  --gold-lt: #e8ba85;
  --bg:      #16161a;
  --bg2:     #1f1f24;
  --bg3:     #2a2a30;
  --text:    #e8e4dc;
  --muted:   #8a8880;
  --border:  rgba(255,255,255,.06);
  --border-gold: rgba(209,159,104,.2);
  --shadow:  rgba(0,0,0,.4);
  --white:   #ffffff;
  --danger:  #c0392b;
  --success: #27ae60;

  --font-head: 'Oswald', sans-serif;
  --font-body: 'Poppins', sans-serif;
  --radius: 4px;
  --radius-lg: 10px;
}

/* ── Light Theme ────────────────────────────────────────── */
[data-theme="light"] {
  --bg:      #f2ede6;
  --bg2:     #faf7f3;
  --bg3:     #ede8e0;
  --text:    #1d1a16;
  --muted:   #7a736a;
  --border:  rgba(0,0,0,.07);
  --border-gold: rgba(180,120,60,.25);
  --shadow:  rgba(0,0,0,.1);
  --white:   #ffffff;
}

/* ── Theme transition ───────────────────────────────────── */
*, *::before, *::after { transition: background-color .25s, color .2s, border-color .2s; }

/* ── Light theme border/divider overrides ───────────────── */
[data-theme="light"] .shop-card          { border-color: rgba(0,0,0,.08); }
[data-theme="light"] .shop-card-footer   { border-color: rgba(0,0,0,.06); }
[data-theme="light"] .info-block         { border-color: rgba(0,0,0,.07); }
[data-theme="light"] .info-row           { border-color: rgba(0,0,0,.06); }
[data-theme="light"] .tabs               { border-color: rgba(0,0,0,.08); }
[data-theme="light"] .price-item         { border-color: rgba(0,0,0,.06); }
[data-theme="light"] .summary-box        { border-color: rgba(0,0,0,.08); }
[data-theme="light"] .sum-row            { border-color: rgba(0,0,0,.06); }
[data-theme="light"] .booking-item       { border-color: rgba(0,0,0,.08); }
[data-theme="light"] .barber-card        { border-color: rgba(0,0,0,.08); }
[data-theme="light"] .barber-photo       { background: var(--bg3); }
[data-theme="light"] .barber-foot        { border-color: rgba(180,120,60,.2); }
[data-theme="light"] .detail-header      { border-color: rgba(0,0,0,.07); background: var(--bg2); }
[data-theme="light"] .nav-header         { border-color: rgba(0,0,0,.07); }
[data-theme="light"] .nav-footer         { border-color: rgba(0,0,0,.07); color: rgba(0,0,0,.3); }
[data-theme="light"] .nav-divider        { background: rgba(0,0,0,.06); }
[data-theme="light"] .slot-btn           { border-color: rgba(0,0,0,.12); }
[data-theme="light"] .wh-item            { border-color: rgba(0,0,0,.06); }
[data-theme="light"] #nav-overlay        { border-color: rgba(0,0,0,.1); background: var(--bg2); }
[data-theme="light"] #nav-backdrop       { background: rgba(0,0,0,.35); }
[data-theme="light"] .pi-dots            { border-color: rgba(180,120,60,.3); }
[data-theme="light"] .error-box          { background: rgba(192,57,43,.08); }

/* ── Theme Toggle Button ────────────────────────────────── */
.theme-btn {
  width: 34px; height: 34px; border-radius: 50%;
  border: 1px solid var(--border-gold);
  background: transparent;
  display: flex; align-items: center; justify-content: center;
  color: var(--gold); font-size: 14px; cursor: pointer;
  transition: background .2s, transform .3s;
  flex-shrink: 0;
}
.theme-btn:active { background: rgba(209,159,104,.15); transform: rotate(20deg); }

html, body {
  height: 100%;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 14px;
  overscroll-behavior: none;
  -webkit-tap-highlight-color: transparent;
}

/* ── Screen System ──────────────────────────────────────── */
#app { position:relative; height:100vh; overflow:hidden; }

.screen {
  position:absolute; inset:0;
  overflow-y:auto; overflow-x:hidden;
  background: var(--bg);
  transform: translateX(100%);
  transition: transform .3s cubic-bezier(.4,0,.2,1);
  will-change: transform;
  padding-bottom: 90px;
}
.screen.active  { transform: translateX(0); }
.screen.leaving { transform: translateX(-20%); pointer-events:none; }
.screen.no-anim { transition: none !important; }

/* ── TopBar ─────────────────────────────────────────────── */
.topbar {
  position: sticky; top:0; z-index: 50;
  background: var(--bg2);
  border-bottom: 1px solid rgba(209,159,104,.15);
  display:flex; align-items:center; gap:10px;
  padding: 13px 16px;
}
.topbar-logo {
  font-family: var(--font-head);
  font-size: 20px; font-weight: 700;
  color: var(--gold); letter-spacing: 2px;
  text-transform: uppercase; flex:1;
  transition: padding-left .2s;
}
.topbar-logo span { color: var(--text); font-weight: 300; }
.topbar-action {
  width: 38px; height: 38px; border-radius: 50%;
  border: 1px solid rgba(209,159,104,.3);
  background: transparent;
  display:flex; align-items:center; justify-content:center;
  color: var(--gold); font-size: 15px; cursor: pointer;
  transition: .2s;
}
.topbar-action:active { background: rgba(209,159,104,.15); }

/* ── Global back button (fixed, over topbar) ────────────── */
#global-back-btn {
  position: fixed; top: 9px; left: 12px; z-index: 200;
  width: 38px; height: 38px; border-radius: 50%;
  border: 1px solid rgba(209,159,104,.3); background: var(--bg2);
  display: none; align-items: center; justify-content: center;
  color: var(--gold); font-size: 15px; cursor: pointer;
  transition: background .2s;
}
#global-back-btn.show { display: flex; }
#global-back-btn:active { background: rgba(209,159,104,.15); }
body.has-back .screen.active .topbar-logo { padding-left: 44px; }

/* ── Avatar upload ──────────────────────────────────────── */
.avatar-wrap { position: relative; width: 72px; height: 72px; flex-shrink: 0; }
.avatar-img {
  width: 72px; height: 72px; border-radius: 50%;
  object-fit: cover; border: 2px solid var(--border-gold);
  background: var(--bg3);
}
.avatar-placeholder {
  width: 72px; height: 72px; border-radius: 50%;
  background: var(--bg3); border: 2px solid var(--border-gold);
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; color: var(--muted);
}
.avatar-upload-btn {
  position: absolute; bottom: 0; right: 0;
  width: 24px; height: 24px; border-radius: 50%;
  background: var(--gold); color: var(--bg); border: 2px solid var(--bg2);
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; cursor: pointer;
}

/* ── Salon logo in registration ─────────────────────────── */
.salon-logo-pick {
  width: 64px; height: 64px; border-radius: 12px;
  border: 1.5px dashed var(--border-gold); background: var(--bg3);
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; cursor: pointer; transition: .2s;
  color: var(--muted); font-size: 10px; gap: 4px; flex-shrink: 0;
}
.salon-logo-pick:active { background: rgba(209,159,104,.08); }
.salon-logo-pick i { font-size: 20px; color: var(--gold); }
.salon-logo-pick img { width: 64px; height: 64px; border-radius: 12px; object-fit: cover; }

/* ── Support screen ─────────────────────────────────────── */
.support-hero {
  display: flex; flex-direction: column; align-items: center;
  padding: 32px 24px 16px; text-align: center;
}
.support-hero-icon { font-size: 48px; margin-bottom: 12px; }
.support-hero-title {
  font-family: var(--font-head); font-size: 22px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1px; color: var(--text);
  margin-bottom: 8px;
}
.support-hero-sub { font-size: 13px; color: var(--muted); line-height: 1.5; }
.support-email-tag {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--bg2); border: 1px solid var(--border-gold);
  border-radius: 20px; padding: 6px 14px; margin: 12px 0;
  font-size: 13px; color: var(--gold); font-family: var(--font-head);
}

/* ── Barber edit screen ─────────────────────────────────── */
.edit-avatar-row {
  display: flex; align-items: center; gap: 16px;
  padding: 16px 14px; background: var(--bg2);
  border-bottom: 1px solid var(--border);
}

/* ── Section Label (Template style) ────────────────────── */
.sec-label {
  font-family: var(--font-head);
  font-size: 11px; font-weight: 600;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--gold);
  padding: 20px 16px 8px;
  display:flex; align-items:center; gap:10px;
}
.sec-label::after {
  content: ''; flex:1; height:1px;
  background: linear-gradient(90deg, rgba(209,159,104,.4), transparent);
}

/* ── Gold Divider ───────────────────────────────────────── */
.gold-line {
  width: 40px; height: 2px;
  background: var(--gold);
  margin: 8px 0 16px;
}

/* ── Shop Card ──────────────────────────────────────────── */
.shop-card {
  margin: 8px 14px;
  background: var(--bg2);
  border: 1px solid rgba(255,255,255,.05);
  border-radius: var(--radius-lg);
  overflow: hidden;
  cursor: pointer;
  transition: border-color .2s, transform .15s;
}
.shop-card:active { transform: scale(.99); border-color: rgba(209,159,104,.4); }

.shop-card-inner {
  display: flex; align-items: center; gap:14px; padding: 14px 16px;
}
.shop-avatar {
  width: 52px; height: 52px; border-radius: 50%;
  background: var(--bg3);
  border: 1.5px solid rgba(209,159,104,.3);
  display:flex; align-items:center; justify-content:center;
  font-size: 22px; flex-shrink:0; overflow:hidden;
}
.shop-avatar img { width:100%; height:100%; object-fit:cover; }
.shop-info { flex:1; min-width:0; }
.shop-name {
  font-family: var(--font-head);
  font-size: 17px; font-weight: 500;
  text-transform: uppercase; letter-spacing:.5px;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}
.shop-addr { color: var(--muted); font-size:12px; margin-top:3px; }
.shop-badge {
  font-family: var(--font-head);
  font-size: 11px; font-weight: 500; letter-spacing:.5px;
  color: var(--gold); text-transform:uppercase;
  white-space:nowrap;
}
.shop-card-footer {
  border-top: 1px solid rgba(255,255,255,.04);
  padding: 9px 16px;
  display: flex; align-items:center; justify-content:space-between;
}
.shop-card-footer span { font-size:12px; color:var(--muted); }
.shop-card-footer i { color: var(--gold); font-size:12px; }

/* ── Shop Cover ─────────────────────────────────────────── */
.cover-wrap { position:relative; overflow:hidden; }
.cover-img {
  width:100%; height:200px; object-fit:cover; display:block;
}
.cover-placeholder {
  width:100%; height:160px;
  background: linear-gradient(135deg, var(--bg3) 0%, var(--bg2) 100%);
  display:flex; align-items:center; justify-content:center;
}
.cover-overlay {
  position:absolute; inset:0;
  background: linear-gradient(to top, rgba(22,22,26,.9) 0%, transparent 50%);
}
.cover-title {
  position:absolute; bottom:0; left:0; right:0;
  padding: 16px;
}
.cover-title h2 {
  font-family: var(--font-head);
  font-size: 26px; font-weight: 700;
  text-transform: uppercase; letter-spacing:1px; color:#fff;
}
.cover-title .gold-sub {
  font-size:11px; color:var(--gold); letter-spacing:2px;
  text-transform:uppercase; font-family:var(--font-head); margin-top:2px;
}

/* ── Info Row ───────────────────────────────────────────── */
.info-block {
  background: var(--bg2);
  border: 1px solid rgba(255,255,255,.05);
  border-radius: var(--radius-lg);
  margin: 8px 14px; padding:12px 16px;
}
.info-row {
  display:flex; align-items:flex-start; gap:12px;
  padding: 7px 0; border-bottom:1px solid rgba(255,255,255,.04);
}
.info-row:last-child { border:none; padding-bottom:0; }
.info-row i { color:var(--gold); width:16px; flex-shrink:0; font-size:13px; margin-top:1px; }
.info-row-text { font-size:13px; line-height:1.45; color:var(--text); }
.info-link { color:var(--gold); text-decoration:none; }

/* ── Tabs ───────────────────────────────────────────────── */
.tabs {
  display:flex; margin: 12px 14px 0;
  border-bottom: 1px solid rgba(255,255,255,.07);
}
.tab {
  flex:1; text-align:center;
  font-family:var(--font-head); font-size:13px; font-weight:500;
  letter-spacing:.5px; text-transform:uppercase;
  padding: 10px 4px; color:var(--muted);
  cursor:pointer; border-bottom: 2px solid transparent;
  transition: .2s; position:relative; top:1px;
}
.tab.active { color:var(--gold); border-bottom-color:var(--gold); }

/* ── Service Pricing List (Template Style) ─────────────── */
.price-list { margin: 0; padding: 0; list-style:none; }
.price-item {
  display:flex; align-items:flex-start; gap:8px;
  padding: 14px 16px;
  border-bottom: 1px solid rgba(255,255,255,.05);
  cursor:pointer; transition:.15s;
}
.price-item:last-child { border:none; }
.price-item:active { background: rgba(209,159,104,.06); }
.price-item.selected { background: rgba(209,159,104,.1); border-color: rgba(209,159,104,.2); }
.price-item.selected .pi-name { color:var(--gold); }

.pi-left { flex:1; min-width:0; }
.pi-name {
  font-family: var(--font-head); font-size:16px; font-weight:500;
  text-transform:uppercase; letter-spacing:.3px; color:var(--text);
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}
.pi-meta { color:var(--muted); font-size:11px; margin-top:3px; letter-spacing:.3px; }
.pi-dots {
  flex:1; border-bottom: 1px dotted rgba(209,159,104,.3);
  margin: 0 6px; align-self:flex-end; margin-bottom:5px;
}
.pi-price {
  font-family:var(--font-head); font-size:16px; font-weight:600;
  color:var(--gold); white-space:nowrap; flex-shrink:0;
}

/* ── Barber Cards ───────────────────────────────────────── */
.barber-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; padding:10px 14px; }
.barber-card {
  background: var(--bg2);
  border: 1px solid rgba(255,255,255,.05);
  border-radius: var(--radius-lg);
  overflow:hidden; cursor:pointer;
  transition:.15s; text-align:center;
}
.barber-card:active { border-color:rgba(209,159,104,.4); transform:scale(.98); }
.barber-card.selected { border-color:var(--gold); }

.barber-photo {
  width:100%; aspect-ratio:1; background:var(--bg3);
  display:flex; align-items:center; justify-content:center;
  font-size:40px; overflow:hidden; position:relative;
}
.barber-photo img { width:100%; height:100%; object-fit:cover; }
.barber-photo::after {
  content:''; position:absolute; bottom:0; left:0; right:0; height:40%;
  background: linear-gradient(to top, rgba(22,22,26,.8), transparent);
}
.barber-foot {
  padding: 10px 8px 12px;
  border-top: 1px solid rgba(209,159,104,.15);
}
.barber-name {
  font-family:var(--font-head); font-size:14px; font-weight:500;
  text-transform:uppercase; letter-spacing:.5px; color:var(--text);
}
.barber-role { font-size:11px; color:var(--gold); letter-spacing:.5px; margin-top:2px; }
.barber-exp { font-size:11px; color:var(--muted); margin-top:3px; }

/* ── Date Input ─────────────────────────────────────────── */
.date-wrap { padding: 8px 14px; }
.date-field {
  width:100%; padding: 13px 16px;
  background: var(--bg2);
  border: 1px solid rgba(209,159,104,.25);
  border-radius: var(--radius);
  color: var(--text); font-family:var(--font-body); font-size:14px;
  color-scheme: dark; outline:none;
  transition:.2s;
}
.date-field:focus { border-color:var(--gold); }

/* ── Time Slots ─────────────────────────────────────────── */
.slots-wrap { padding: 6px 14px; }
.slots-grid {
  display:grid; grid-template-columns:repeat(4,1fr); gap:8px;
}
.slot-btn {
  padding:10px 4px; text-align:center;
  font-family:var(--font-head); font-size:14px; font-weight:500;
  letter-spacing:.5px;
  background: var(--bg2);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--radius);
  color: var(--text); cursor:pointer; transition:.15s;
}
.slot-btn:active { transform:scale(.94); }
.slot-btn.selected {
  background: var(--gold);
  border-color: var(--gold);
  color: var(--bg);
  font-weight: 600;
}

/* ── Summary (Confirm) ──────────────────────────────────── */
.summary-box {
  margin: 8px 14px;
  background: var(--bg2);
  border: 1px solid rgba(255,255,255,.06);
  border-radius: var(--radius-lg);
  overflow:hidden;
}
.sum-row {
  display:flex; justify-content:space-between; align-items:center;
  padding: 12px 16px;
  border-bottom: 1px solid rgba(255,255,255,.05);
}
.sum-row:last-child { border:none; }
.sum-label {
  font-family:var(--font-head); font-size:12px; font-weight:500;
  letter-spacing:1px; text-transform:uppercase; color:var(--muted);
}
.sum-val { font-size:14px; font-weight:500; text-align:right; max-width:60%; }
.sum-price {
  font-family:var(--font-head); font-size:20px; font-weight:700; color:var(--gold);
}

/* ── Primary Button ─────────────────────────────────────── */
.btn-primary {
  display:flex; align-items:center; justify-content:center; gap:8px;
  width:calc(100% - 28px); margin:10px 14px;
  padding: 15px; border:none; border-radius:var(--radius); cursor:pointer;
  font-family:var(--font-head); font-size:14px; font-weight:600;
  letter-spacing:2px; text-transform:uppercase;
  background: var(--gold); color: var(--bg);
  transition:.15s;
}
.btn-primary:active { opacity:.85; }
.btn-secondary {
  background: transparent; color:var(--text);
  border: 1px solid rgba(255,255,255,.2);
}
.btn-danger {
  background: rgba(192,57,43,.15); color:#e74c3c;
  border: 1px solid rgba(192,57,43,.3);
}

/* ── Working Hours ──────────────────────────────────────── */
.wh-grid { display:grid; grid-template-columns:1fr 1fr; gap:0; }
.wh-item {
  padding:9px 0; border-bottom:1px solid rgba(255,255,255,.05);
}
.wh-item:nth-last-child(-n+2) { border-bottom:none; }
.wh-day {
  font-family:var(--font-head); font-size:12px; letter-spacing:1px;
  text-transform:uppercase; color:var(--muted);
}
.wh-time { font-size:13px; font-weight:500; margin-top:3px; }
.wh-off { color:var(--muted); font-style:italic; }

/* ── Booking Row ────────────────────────────────────────── */
.booking-list { margin:8px 14px; }
.booking-item {
  background: var(--bg2);
  border: 1px solid rgba(255,255,255,.05);
  border-radius: var(--radius-lg);
  padding: 14px 16px;
  margin-bottom: 8px;
  cursor:pointer; transition:.15s;
  display:flex; align-items:flex-start; justify-content:space-between; gap:10px;
}
.booking-item:active { border-color:rgba(209,159,104,.3); }
.booking-item:last-child { margin-bottom:0; }
.booking-shop {
  font-family:var(--font-head); font-size:15px; font-weight:500;
  text-transform:uppercase; letter-spacing:.5px;
}
.booking-service { font-size:12px; color:var(--muted); margin-top:3px; }
.booking-when {
  display:flex; align-items:center; gap:6px; margin-top:8px;
  font-size:12px; color:var(--gold);
}

/* ── Status Badges ──────────────────────────────────────── */
.badge {
  font-family:var(--font-head); font-size:10px; font-weight:600;
  letter-spacing:1px; text-transform:uppercase;
  padding: 4px 10px; border-radius:20px; flex-shrink:0;
}
.badge-pending   { background:rgba(230,176,9,.12);  color:#e6b009; border:1px solid rgba(230,176,9,.25); }
.badge-confirmed { background:rgba(39,174,96,.12);  color:#27ae60; border:1px solid rgba(39,174,96,.25); }
.badge-cancelled { background:rgba(192,57,43,.12);  color:#e74c3c; border:1px solid rgba(192,57,43,.25); }
.badge-completed { background:rgba(127,140,141,.12);color:#95a5a6; border:1px solid rgba(127,140,141,.25); }
.badge-no_show   { background:rgba(192,57,43,.12);  color:#e74c3c; border:1px solid rgba(192,57,43,.25); }

/* ── Success Screen ─────────────────────────────────────── */
.success-wrap {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  min-height:80vh; padding:32px 24px; text-align:center;
}
.success-circle {
  width:90px; height:90px; border-radius:50%;
  border: 2px solid var(--gold);
  display:flex; align-items:center; justify-content:center;
  margin-bottom:24px; position:relative;
}
.success-circle::before {
  content:''; position:absolute; inset:-8px;
  border-radius:50%; border:1px solid rgba(209,159,104,.2);
}
.success-circle i { font-size:38px; color:var(--gold); }
.success-title {
  font-family:var(--font-head); font-size:28px; font-weight:700;
  text-transform:uppercase; letter-spacing:2px; margin-bottom:8px;
}
.success-sub { color:var(--muted); font-size:13px; line-height:1.6; max-width:280px; }

/* ── States ─────────────────────────────────────────────── */
.loading-wrap {
  display:flex; flex-direction:column; align-items:center;
  justify-content:center; padding:60px 20px; gap:14px;
}
.spinner {
  width:24px; height:24px;
  border:2px solid rgba(209,159,104,.2);
  border-top-color:var(--gold); border-radius:50%;
  animation:spin .7s linear infinite;
}
@keyframes spin { to { transform:rotate(360deg); } }
.spinner-text { font-size:12px; color:var(--muted); letter-spacing:1px; }

.empty-wrap { text-align:center; padding:50px 20px; }
.empty-icon { font-size:44px; margin-bottom:14px; opacity:.5; }
.empty-title {
  font-family:var(--font-head); font-size:18px; letter-spacing:1px;
  text-transform:uppercase; color:var(--muted); margin-bottom:8px;
}
.empty-sub { font-size:13px; color:var(--muted); }

.error-box {
  margin:8px 14px; padding:12px 14px;
  background:rgba(192,57,43,.1); color:#e74c3c;
  border:1px solid rgba(192,57,43,.25); border-radius:var(--radius);
  font-size:13px; display:none;
}
.success-box {
  margin:8px 14px; padding:12px 14px;
  background:rgba(39,174,96,.1); color:#27ae60;
  border:1px solid rgba(39,174,96,.25); border-radius:var(--radius);
  font-size:13px; display:flex; align-items:center; gap:8px;
}

/* ── Booking Detail ─────────────────────────────────────── */
.detail-header {
  display:flex; align-items:center; gap:14px; padding:16px;
  background:var(--bg2); border-bottom:1px solid rgba(255,255,255,.05);
}
.detail-icon {
  width:48px; height:48px; border-radius:50%;
  border: 1px solid rgba(209,159,104,.3);
  display:flex; align-items:center; justify-content:center;
  font-size:20px; background:rgba(209,159,104,.1);
  flex-shrink:0;
}
.detail-shop {
  font-family:var(--font-head); font-size:17px; font-weight:500;
  text-transform:uppercase; letter-spacing:.5px;
}
.detail-service { font-size:12px; color:var(--muted); margin-top:3px; }

/* ── Loading Screen ─────────────────────────────────────── */
#s-loading {
  display:flex; flex-direction:column;
  align-items:center; justify-content:center; height:100vh; gap:20px;
}
.load-logo {
  font-family:var(--font-head); font-size:32px; font-weight:700;
  color:var(--gold); letter-spacing:4px; text-transform:uppercase;
}
.load-logo span { color:rgba(255,255,255,.3); font-weight:300; }
.load-line {
  width:80px; height:1px; background:rgba(209,159,104,.3); position:relative; overflow:hidden;
}
.load-line::after {
  content:''; position:absolute; left:-100%; top:0;
  width:100%; height:100%; background:var(--gold);
  animation: loadline 1.2s ease-in-out infinite;
}
@keyframes loadline { to { left:200%; } }

/* ── Role Selection ─────────────────────────────────────── */
.role-hero {
  text-align: center; padding: 40px 24px 24px;
}
.role-hero-icon { font-size: 48px; margin-bottom: 16px; }
.role-hero h2 {
  font-family: var(--font-head); font-size: 24px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 2px; margin-bottom: 8px;
}
.role-hero p { color: var(--muted); font-size: 13px; line-height: 1.6; }

.role-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 8px 14px 24px; }
.role-card {
  background: var(--bg2); border: 1.5px solid var(--border);
  border-radius: var(--radius-lg); padding: 22px 14px;
  text-align: center; cursor: pointer; transition: .2s;
}
.role-card:active { transform: scale(.97); border-color: var(--gold); }
.role-card.selected { border-color: var(--gold); background: rgba(209,159,104,.08); }
.role-card-icon { font-size: 32px; margin-bottom: 10px; }
.role-card-title {
  font-family: var(--font-head); font-size: 15px; font-weight: 600;
  text-transform: uppercase; letter-spacing: 1px; color: var(--text);
}
.role-card-desc { font-size: 11px; color: var(--muted); margin-top: 5px; line-height: 1.4; }

/* ── Step Indicator ─────────────────────────────────────── */
.step-bar {
  display: flex; align-items: center; justify-content: center;
  gap: 6px; padding: 14px 16px 6px;
}
.step-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--bg3); transition: .3s;
}
.step-dot.active { background: var(--gold); width: 24px; border-radius: 4px; }
.step-dot.done   { background: rgba(209,159,104,.4); }

.step-label {
  text-align: center; padding: 4px 16px 16px;
  font-family: var(--font-head); font-size: 11px;
  letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
}

/* ── Form Fields ─────────────────────────────────────────── */
.form-group { padding: 6px 14px; }
.form-label {
  font-family: var(--font-head); font-size: 11px; font-weight: 500;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--gold); margin-bottom: 6px; display: block;
}
.form-input {
  width: 100%; padding: 12px 14px;
  background: var(--bg2); border: 1px solid var(--border-gold);
  border-radius: var(--radius); color: var(--text);
  font-family: var(--font-body); font-size: 14px;
  outline: none; transition: border-color .2s;
}
.form-input:focus { border-color: var(--gold); }
.form-input::placeholder { color: var(--muted); }
textarea.form-input { resize: none; height: 80px; line-height: 1.5; }

/* ── Spec Cards ──────────────────────────────────────────── */
.spec-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; padding: 6px 14px; }
.spec-card {
  background: var(--bg2); border: 1.5px solid var(--border);
  border-radius: var(--radius-lg); padding: 16px 8px;
  text-align: center; cursor: pointer; transition: .2s;
}
.spec-card:active { transform: scale(.96); }
.spec-card.selected { border-color: var(--gold); background: rgba(209,159,104,.08); }
.spec-card-icon { font-size: 26px; margin-bottom: 6px; }
.spec-card-label {
  font-family: var(--font-head); font-size: 12px; font-weight: 500;
  text-transform: uppercase; letter-spacing: .5px;
}

/* ── Service Picker ──────────────────────────────────────── */
.svc-pick-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px; border-bottom: 1px solid var(--border);
  cursor: pointer; transition: .15s;
}
.svc-pick-item:last-child { border: none; }
.svc-check {
  width: 20px; height: 20px; border-radius: 4px; flex-shrink: 0;
  border: 1.5px solid var(--border-gold);
  display: flex; align-items: center; justify-content: center;
  color: var(--bg); font-size: 11px; transition: .2s;
}
.svc-pick-item.selected .svc-check {
  background: var(--gold); border-color: var(--gold);
}
.svc-pick-info { flex: 1; }
.svc-pick-name {
  font-family: var(--font-head); font-size: 14px; font-weight: 500;
  text-transform: uppercase; letter-spacing: .3px;
}
.svc-pick-meta { font-size: 11px; color: var(--muted); margin-top: 2px; }
.svc-pick-price { font-family: var(--font-head); font-size: 14px; color: var(--gold); }

/* ── Service price editor (shown when selected) ─────────── */
.svc-price-row {
  display: none; grid-template-columns: 1fr 80px; gap: 8px;
  padding: 4px 14px 10px 46px;
}
.svc-pick-item.selected + .svc-price-row { display: grid; }
.svc-price-row .form-input { font-size: 13px; padding: 6px 10px; height: 36px; }

/* ── Salon selection list ────────────────────────────────── */
.salon-pick-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px; border-bottom: 1px solid var(--border);
  cursor: pointer; transition: .15s;
}
.salon-pick-item:last-child { border: none; }
.salon-pick-item:active { background: rgba(209,159,104,.05); }
.salon-pick-item.selected { background: rgba(209,159,104,.06); }
.salon-pick-radio {
  width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0;
  border: 2px solid var(--border-gold);
  display: flex; align-items: center; justify-content: center; transition: .2s;
}
.salon-pick-item.selected .salon-pick-radio {
  border-color: var(--gold); background: var(--gold);
}
.salon-pick-item.selected .salon-pick-radio::after {
  content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--bg);
}
.salon-pick-info { flex: 1; }
.salon-pick-name {
  font-family: var(--font-head); font-size: 14px; font-weight: 600;
  text-transform: uppercase; letter-spacing: .3px;
}
.salon-pick-addr { font-size: 12px; color: var(--muted); margin-top: 2px; }
.salon-new-btn {
  display: flex; align-items: center; gap: 10px;
  padding: 14px; margin: 6px 14px;
  background: var(--bg2); border: 1.5px dashed var(--border-gold);
  border-radius: var(--radius-lg); cursor: pointer; transition: .2s;
  font-family: var(--font-head); font-size: 13px; font-weight: 500;
  text-transform: uppercase; letter-spacing: .5px; color: var(--gold);
}
.salon-new-btn.selected { background: rgba(209,159,104,.08); border-style: solid; }
.salon-new-btn i { font-size: 16px; }

/* ── Custom service add row ──────────────────────────────── */
.custom-svc-row {
  display: grid; grid-template-columns: 1fr 70px 90px; gap: 8px; padding: 6px 14px;
}

/* ── Barber Dashboard ────────────────────────────────────── */
.barber-profile-card {
  margin: 12px 14px 4px;
  background: var(--bg2); border: 1px solid var(--border-gold);
  border-radius: var(--radius-lg); padding: 16px;
}
.bpc-name {
  font-family: var(--font-head); font-size: 20px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1px; color: var(--text);
}
.bpc-meta { display: flex; align-items: center; gap: 8px; margin-top: 6px; }
.spec-badge {
  font-size: 11px; font-family: var(--font-head); letter-spacing: .5px;
  text-transform: uppercase; color: var(--gold);
  border: 1px solid var(--border-gold); border-radius: 4px;
  padding: 2px 8px;
}
.bpc-exp { font-size: 12px; color: var(--muted); }

.empty-svc-prompt {
  display: flex; flex-direction: column; align-items: center;
  padding: 24px 14px; text-align: center;
  background: var(--bg2); border: 1px dashed var(--border-gold);
  border-radius: var(--radius-lg); margin: 4px 14px 8px;
  color: var(--text);
}

.dash-stat-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
  padding: 8px 14px;
}
.dash-stat {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 16px 14px; text-align: center;
}
.dash-stat-num {
  font-family: var(--font-head); font-size: 28px; font-weight: 700; color: var(--gold);
}
.dash-stat-label { font-size: 11px; color: var(--muted); letter-spacing: .5px; margin-top: 4px; }

.dash-appt {
  display: flex; gap: 12px; padding: 12px 14px;
  border-bottom: 1px solid var(--border); cursor: pointer; transition: .15s;
}
.dash-appt:active { background: rgba(209,159,104,.05); }
.dash-time-col { text-align: center; flex-shrink: 0; width: 44px; }
.dash-time {
  font-family: var(--font-head); font-size: 16px; font-weight: 600; color: var(--gold);
}
.dash-end-time { font-size: 10px; color: var(--muted); }
.dash-client { font-family: var(--font-head); font-size: 14px; font-weight: 500;
  text-transform: uppercase; letter-spacing: .3px; }
.dash-svc { font-size: 12px; color: var(--muted); margin-top: 2px; }
.dash-price { font-size: 12px; color: var(--gold); margin-top: 2px; }

/* ── Toggle switch ───────────────────────────────────────── */
.toggle-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 16px; background: var(--bg2);
  border: 1px solid var(--border); border-radius: var(--radius-lg);
  margin: 4px 14px;
}
.toggle-row-label { font-size: 14px; font-weight: 500; }
.toggle-row-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }
.toggle {
  position: relative; width: 44px; height: 24px; flex-shrink: 0;
}
.toggle input { opacity: 0; width: 0; height: 0; position: absolute; }
.toggle-track {
  position: absolute; inset: 0; border-radius: 12px;
  background: var(--bg3); cursor: pointer; transition: .3s;
}
.toggle input:checked + .toggle-track { background: var(--gold); }
.toggle-track::after {
  content: ''; position: absolute;
  width: 18px; height: 18px; left: 3px; top: 3px;
  background: white; border-radius: 50%; transition: .3s;
}
.toggle input:checked + .toggle-track::after { transform: translateX(20px); }

/* ── Scrollbar ──────────────────────────────────────────── */
::-webkit-scrollbar { width:3px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:rgba(209,159,104,.3); border-radius:3px; }

/* ── Burger Button ──────────────────────────────────────── */
.burger {
  width: 38px; height: 38px; border-radius: 50%;
  border: 1px solid rgba(209,159,104,.3);
  background: transparent;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; flex-direction: column; gap: 5px;
  padding: 10px; transition: .2s; flex-shrink:0;
}
.burger:active { background: rgba(209,159,104,.15); }
.burger span {
  display: block; width: 16px; height: 1.5px;
  background: var(--gold);
  transition: transform .3s, opacity .3s, width .3s;
  transform-origin: center;
}
.burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.burger.open span:nth-child(2) { opacity: 0; width: 0; }
.burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

/* ── Nav Backdrop ───────────────────────────────────────── */
#nav-backdrop {
  position: fixed; inset: 0; z-index: 199;
  background: rgba(0,0,0,.55);
  opacity: 0; pointer-events: none;
  transition: opacity .3s;
}
#nav-backdrop.open { opacity: 1; pointer-events: all; }

/* ── Side Drawer ────────────────────────────────────────── */
#nav-overlay {
  position: fixed; top: 0; right: 0; bottom: 0;
  width: 72%; max-width: 280px;
  z-index: 200;
  background: var(--bg2);
  border-left: 1px solid rgba(209,159,104,.15);
  display: flex; flex-direction: column;
  transform: translateX(100%);
  transition: transform .32s cubic-bezier(.4,0,.2,1);
  overflow: hidden;
}
#nav-overlay.open { transform: translateX(0); }

/* gold accent bar */
#nav-overlay::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
  background: linear-gradient(to bottom, transparent 0%, var(--gold) 40%, transparent 100%);
}

/* ── Drawer Header ──────────────────────────────────────── */
.nav-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 16px 14px;
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.nav-brand {
  font-family: var(--font-head); font-size: 16px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase; color: var(--gold);
}
.nav-brand span { color: rgba(255,255,255,.35); font-weight: 300; }

.nav-close {
  width: 32px; height: 32px; border-radius: 50%;
  border: 1px solid rgba(209,159,104,.2);
  background: transparent;
  display: flex; align-items: center; justify-content: center;
  color: var(--muted); font-size: 14px; cursor: pointer;
  transition: .2s;
}
.nav-close:active { background: rgba(209,159,104,.15); color: var(--gold); }

/* ── Nav Items ──────────────────────────────────────────── */
.nav-list { list-style: none; padding: 8px 0; flex: 1; }
.nav-item { }

.nav-link {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 20px; cursor: pointer;
  font-family: var(--font-head); font-size: 15px; font-weight: 500;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--text);
  border-left: 2px solid transparent;
  transition: color .2s, background .2s, border-color .2s;
}
.nav-link:active {
  color: var(--gold);
  background: rgba(209,159,104,.07);
  border-left-color: var(--gold);
}
.nav-link i {
  width: 18px; text-align: center;
  font-size: 14px; color: var(--gold); opacity: .75;
}

.nav-divider {
  height: 1px; background: rgba(255,255,255,.05);
  margin: 6px 20px;
}

/* ── Drawer Footer ──────────────────────────────────────── */
.nav-footer {
  padding: 14px 20px;
  border-top: 1px solid rgba(255,255,255,.06);
  font-size: 10px; color: rgba(255,255,255,.18);
  letter-spacing: 2px; text-transform: uppercase;
  font-family: var(--font-head);
}
</style>
</head>
<body>

<!-- ══════════ NAV BACKDROP + DRAWER (body darajasida) ══════════ -->
<!-- Global back button (fixed, outside #app) -->
<button id="global-back-btn" onclick="goBack()">
  <i class="fa-solid fa-arrow-left"></i>
</button>

<div id="nav-backdrop" onclick="closeNav()"></div>
<div id="nav-overlay">
  <div class="nav-header">
    <div class="nav-brand">Barber<span>Shop</span></div>
    <button class="nav-close" onclick="closeNav()"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <ul class="nav-list">
    <li class="nav-item">
      <div class="nav-link" onclick="navGo('shops')">
        <i class="fa-solid fa-store"></i> Salonlar
      </div>
    </li>
    <div class="nav-divider"></div>
    <li class="nav-item">
      <div class="nav-link" onclick="navGo('my-bookings')">
        <i class="fa-regular fa-calendar-check"></i> Bronlarim
      </div>
    </li>
    <div class="nav-divider"></div>
    <li class="nav-item" id="nav-barber-item" style="display:none;">
      <div class="nav-link" onclick="navGo('barber-dash')">
        <i class="fa-solid fa-scissors"></i> Kabinetim
      </div>
    </li>
    <li class="nav-item" id="nav-become-barber" style="display:none;">
      <div class="nav-link" onclick="navGo('become-barber')" style="color:var(--gold);">
        <i class="fa-solid fa-plus"></i> Barber bo'lish
      </div>
    </li>
    <div class="nav-divider"></div>
    <li class="nav-item">
      <div class="nav-link" onclick="navGo('support')">
        <i class="fa-regular fa-circle-question"></i> Yordam
      </div>
    </li>
  </ul>
  <div class="nav-footer">Online Booking · 2025</div>
</div>

<div id="app">

<!-- ══════════ LOADING ══════════ -->
<div class="screen active no-anim" id="s-loading">
  <div class="load-logo">Barber<span>Shop</span></div>
  <div class="load-line"></div>
</div>

<!-- ══════════ SHOPS LIST ══════════ -->
<div class="screen" id="s-shops">
  <div class="topbar">
    <div class="topbar-logo">Barber<span>Shop</span></div>
    <button class="theme-btn" id="theme-btn-main" onclick="toggleTheme()" title="Tema o'zgartirish"><i class="fa-solid fa-moon"></i></button>
    <button class="burger" onclick="openNav()" aria-label="Menyu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div id="shops-content">
    <div class="loading-wrap"><div class="spinner"></div><div class="spinner-text">YUKLANMOQDA</div></div>
  </div>
</div>

<!-- ══════════ SHOP DETAIL ══════════ -->
<div class="screen" id="s-shop">
  <div id="shop-detail-content">
    <div class="loading-wrap"><div class="spinner"></div></div>
  </div>
</div>

<!-- ══════════ SERVICE SELECT ══════════ -->
<div class="screen" id="s-service">
  <div class="topbar">
    <div class="topbar-logo">Xizmat</div>
    <button class="theme-btn theme-btn-topbar" onclick="toggleTheme()"><i class="fa-solid fa-moon"></i></button><button class="burger" onclick="openNav()"><span></span><span></span><span></span></button>
  </div>
  <div id="service-content">
    <div class="loading-wrap"><div class="spinner"></div></div>
  </div>
</div>

<!-- ══════════ BARBER SELECT ══════════ -->
<div class="screen" id="s-barber">
  <div class="topbar">
    <div class="topbar-logo">Sartarosh</div>
    <button class="theme-btn theme-btn-topbar" onclick="toggleTheme()"><i class="fa-solid fa-moon"></i></button><button class="burger" onclick="openNav()"><span></span><span></span><span></span></button>
  </div>
  <div id="barber-content">
    <div class="loading-wrap"><div class="spinner"></div></div>
  </div>
</div>

<!-- ══════════ DATE & TIME ══════════ -->
<div class="screen" id="s-datetime">
  <div class="topbar">
    <div class="topbar-logo">Vaqt</div>
    <button class="theme-btn theme-btn-topbar" onclick="toggleTheme()"><i class="fa-solid fa-moon"></i></button><button class="burger" onclick="openNav()"><span></span><span></span><span></span></button>
  </div>
  <div class="sec-label">Sana tanlang</div>
  <div class="date-wrap">
    <input type="date" class="date-field" id="date-input">
  </div>
  <div id="slots-area">
    <div class="empty-wrap" style="padding:20px;">
      <div class="empty-sub" style="color:var(--muted);font-size:12px;letter-spacing:1px;">SANA TANLANG</div>
    </div>
  </div>
</div>

<!-- ══════════ CONFIRM ══════════ -->
<div class="screen" id="s-confirm">
  <div class="topbar">
    <div class="topbar-logo">Tasdiqlash</div>
    <button class="theme-btn theme-btn-topbar" onclick="toggleTheme()"><i class="fa-solid fa-moon"></i></button><button class="burger" onclick="openNav()"><span></span><span></span><span></span></button>
  </div>
  <div class="sec-label">Bron ma'lumotlari</div>
  <div class="summary-box" id="confirm-summary"></div>
  <div class="error-box" id="confirm-err"></div>
</div>

<!-- ══════════ SUCCESS ══════════ -->
<div class="screen" id="s-success">
  <div class="success-wrap">
    <div class="success-circle">
