    <div class="support-hero-title">Murojaat qiling</div>
    <div class="support-hero-sub">Savol yoki takliflaringizni yuboring,<br>tez orada javob beramiz.</div>
    <div class="support-email-tag">
      <i class="fa-solid fa-envelope"></i> sayfulloh.dev@gmail.com
    </div>
  </div>

  <div class="form-group">
