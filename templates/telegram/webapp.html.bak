  <div class="success-box" id="support-ok" style="display:none;">
    <i class="fa-solid fa-circle-check"></i> Xabaringiz yuborildi! Tez orada javob beramiz.
  </div>
  <button class="btn-primary" id="support-send-btn" onclick="submitSupport()">
    <i class="fa-solid fa-paper-plane"></i> Yuborish
  </button>
</div>

</div><!-- #app -->

<script>
// ══════════════════════════════════════════════════════
// Telegram WebApp Init
// ══════════════════════════════════════════════════════
const tg = window.Telegram.WebApp;
tg.expand();
tg.ready();
tg.enableClosingConfirmation();

const DEBUG = {{ DEBUG|yesno:"true,false" }};

// ══════════════════════════════════════════════════════
// State
// ══════════════════════════════════════════════════════
const bk = {
  shopSlug:null, shopName:null,
  serviceId:null, serviceName:null, serviceDuration:null, servicePrice:null,
  barberId:null, barberName:null,
  date:null, time:null,
};
let shopCache = null;
let screenStack = [];

// ══════════════════════════════════════════════════════
// Navigation
// ══════════════════════════════════════════════════════
function goTo(id) {
  const cur = document.querySelector('.screen.active');
  const nxt = document.getElementById(id);
  if (!nxt || (cur && cur.id === id)) return;
  screenStack.push(id);
  if (cur) cur.classList.add('leaving');
  nxt.classList.add('active');
  setTimeout(() => { if (cur) cur.classList.remove('active','leaving'); }, 300);
  updateNav();
}

function goBack() {
  if (screenStack.length <= 1) return;
  screenStack.pop();
  const prev = screenStack[screenStack.length - 1];
  const cur = document.querySelector('.screen.active');
  const tgt = document.getElementById(prev);
  if (!tgt) return;
  tgt.style.transform = 'translateX(-20%)';
  tgt.classList.add('active');
  requestAnimationFrame(() => {
    tgt.style.transition = 'transform .3s cubic-bezier(.4,0,.2,1)';
    tgt.style.transform = 'translateX(0)';
  });
  setTimeout(() => {
    tgt.style.transition = '';
    tgt.style.transform = '';
    if (cur) cur.classList.remove('active');
  }, 300);
  updateNav();
}

function updateNav() {
  const hasBack = screenStack.length > 1;
  tg.BackButton[hasBack ? 'show' : 'hide']();
  tg.MainButton.hide();
  // In-app back button
  const backBtn = document.getElementById('global-back-btn');
  if (backBtn) backBtn.classList.toggle('show', hasBack);
  document.body.classList.toggle('has-back', hasBack);
}

tg.BackButton.onClick(goBack);

function first(id) {
  screenStack = [id];
  document.querySelectorAll('.screen').forEach(s => {
    s.classList.remove('active','leaving','no-anim');
  });
  const el = document.getElementById(id);
  el.classList.add('active','no-anim');
  requestAnimationFrame(() => el.classList.remove('no-anim'));
  updateNav();
}

// ══════════════════════════════════════════════════════
// HTTP
// ══════════════════════════════════════════════════════
function authHeaders() {
  const h = { 'Content-Type':'application/json' };
  if (tg.initData) h['Authorization'] = 'tma ' + tg.initData;
  return h;
}
function csrf() {
  const m = document.cookie.match(/csrftoken=([^;]+)/);
  return m ? m[1] : '';
}
async function GET(path) {
  const r = await fetch(path, { headers: authHeaders() });
  if (!r.ok) throw new Error((await r.json()).error || r.statusText);
  return r.json();
}
async function POST(path, body) {
  const r = await fetch(path, {
    method:'POST',
    headers: { ...authHeaders(), 'X-CSRFToken': csrf() },
    body: JSON.stringify(body),
  });
  const d = await r.json();
  if (!r.ok) throw new Error(d.error || r.statusText);
  return d;
}

// ══════════════════════════════════════════════════════
// Shops List
// ══════════════════════════════════════════════════════
async function loadShops() {
  const el = document.getElementById('shops-content');
  try {
    const { shops } = await GET('/api/shops/');
    if (!shops.length) {
      el.innerHTML = `<div class="empty-wrap"><div class="empty-icon">✂️</div>
        <div class="empty-title">Salonlar yo'q</div></div>`;
      return;
    }
    let html = '<div class="sec-label">Salonlar</div>';
    shops.forEach(s => {
      html += `
      <div class="shop-card" onclick="openShop('${s.slug}')">
        <div class="shop-card-inner">
          <div class="shop-avatar">
            ${s.logo_url ? `<img src="${s.logo_url}" alt="">` : '✂️'}
          </div>
          <div class="shop-info">
            <div class="shop-name">${esc(s.name)}</div>
            <div class="shop-addr"><i class="fa-solid fa-location-dot" style="color:var(--gold);margin-right:5px;font-size:10px;"></i>${esc(s.address)}</div>
          </div>
        </div>
        <div class="shop-card-footer">
          <span><i class="fa-solid fa-scissors" style="color:var(--gold);margin-right:5px;font-size:10px;"></i>${s.barbers_count} sartarosh</span>
          <i class="fa-solid fa-chevron-right"></i>
        </div>
      </div>`;
    });
    el.innerHTML = html;
  } catch(e) {
    el.innerHTML = `<div class="empty-wrap"><div class="empty-icon">⚠️</div>
      <div class="empty-title">Xatolik</div><div class="empty-sub">${esc(e.message)}</div></div>`;
  }
}

// ══════════════════════════════════════════════════════
// Shop Detail
// ══════════════════════════════════════════════════════
async function openShop(slug) {
  goTo('s-shop');
  const el = document.getElementById('shop-detail-content');
  el.innerHTML = '<div class="loading-wrap"><div class="spinner"></div></div>';
  try {
    const s = await GET(`/api/shops/${slug}/`);
    shopCache = s;
    bk.shopSlug = s.slug; bk.shopName = s.name;

    const coverHtml = s.cover_url
      ? `<div class="cover-wrap">
           <img class="cover-img" src="${s.cover_url}" alt="">
           <div class="cover-overlay"></div>
           <div class="cover-title">
             <h2>${esc(s.name)}</h2>
             <div class="gold-sub">${s.barbers.length} Master Barber</div>
           </div>
         </div>`
      : `<div class="cover-placeholder">
           <div style="text-align:center;">
             <div style="font-size:48px;margin-bottom:8px;">✂️</div>
             <div style="font-family:var(--font-head);font-size:22px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--gold);">${esc(s.name)}</div>
           </div>
         </div>`;

    el.innerHTML = `
      ${coverHtml}
      ${s.description ? `<div style="padding:14px 16px;color:var(--muted);font-size:13px;line-height:1.6;border-bottom:1px solid rgba(255,255,255,.04);">${esc(s.description)}</div>` : ''}
      <div class="info-block">
        <div class="info-row"><i class="fa-solid fa-location-dot"></i><span class="info-row-text">${esc(s.address)}</span></div>
        <div class="info-row"><i class="fa-solid fa-phone"></i><span class="info-row-text">${esc(s.phone)}</span></div>
        ${s.telegram_url ? `<div class="info-row"><i class="fa-brands fa-telegram"></i><a href="${s.telegram_url}" class="info-link">Telegram kanal</a></div>` : ''}
        ${s.instagram_url ? `<div class="info-row"><i class="fa-brands fa-instagram"></i><a href="${s.instagram_url}" class="info-link">Instagram</a></div>` : ''}
      </div>

      <div class="tabs" id="shop-tabs">
        <div class="tab active" onclick="shopTab('services',this)">Xizmatlar (${s.services.length})</div>
        <div class="tab" onclick="shopTab('barbers',this)">Ustalar (${s.barbers.length})</div>
        <div class="tab" onclick="shopTab('hours',this)">Ish vaqti</div>
      </div>

      <div id="tab-services">${renderServices(s.services)}</div>
      <div id="tab-barbers" style="display:none;">${renderBarbers(s.barbers)}</div>
      <div id="tab-hours" style="display:none;">${renderHours(s.working_hours)}</div>
    `;

    tg.MainButton.setText('✂  BRON QILISH').show().onClick(() => {
      tg.MainButton.offClick();
      startBooking();
    });
  } catch(e) {
    el.innerHTML = `<div class="empty-wrap"><div class="empty-icon">⚠️</div>
      <div class="empty-title">Xatolik</div><div class="empty-sub">${esc(e.message)}</div></div>`;
  }
}

function shopTab(name, el) {
  document.querySelectorAll('#shop-tabs .tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  ['services','barbers','hours'].forEach(n =>
    document.getElementById('tab-'+n).style.display = n===name ? '' : 'none'
  );
}

function renderServices(services) {
  if (!services.length) return `<div class="empty-wrap"><div class="empty-sub">Xizmatlar topilmadi</div></div>`;
  let html = '<ul class="price-list">';
  services.forEach(s => {
    html += `
    <li class="price-item" onclick="pickService('${s.id}','${esc(s.name)}',${s.duration},'${s.price}')">
      <div class="pi-left">
        <div class="pi-name">${esc(s.name)}</div>
        <div class="pi-meta">${s.duration} daqiqa${s.category ? ' · ' + esc(s.category) : ''}</div>
      </div>
      <div class="pi-dots"></div>
      <div class="pi-price">${fmtP(s.price)}</div>
    </li>`;
  });
  return html + '</ul>';
}

function renderBarbers(barbers) {
  if (!barbers.length) return `<div class="empty-wrap"><div class="empty-sub">Ustalar topilmadi</div></div>`;
  let html = '<div class="barber-grid">';
  barbers.forEach(b => {
    html += `
    <div class="barber-card" onclick="pickBarberFromShop('${b.id}','${esc(b.name)}',${b.slot_duration})">
      <div class="barber-photo">
        ${b.avatar_url ? `<img src="${b.avatar_url}" alt="">` : '💈'}
      </div>
      <div class="barber-foot">
        <div class="barber-name">${esc(b.name)}</div>
        <div class="barber-role">Master Barber</div>
        <div class="barber-exp">${b.experience_years} yil tajriba</div>
      </div>
    </div>`;
  });
  return html + '</div>';
}

function renderHours(hours) {
  if (!hours.length) return `<div class="empty-wrap"><div class="empty-sub">Ma'lumot yo'q</div></div>`;
  let html = '<div class="info-block" style="margin-top:10px;"><div class="wh-grid">';
  hours.forEach(h => {
    const time = h.is_day_off
      ? '<div class="wh-time wh-off">Dam olish</div>'
      : `<div class="wh-time">${h.open} – ${h.close}</div>`;
    html += `<div class="wh-item"><div class="wh-day">${h.day_name.slice(0,3)}</div>${time}</div>`;
  });
  return html + '</div></div>';
}

// ══════════════════════════════════════════════════════
// Booking Flow
// ══════════════════════════════════════════════════════
function startBooking() {
  bk.serviceId = bk.serviceName = bk.serviceDuration = bk.servicePrice = null;
  bk.barberId = bk.barberName = null;
  bk.date = bk.time = null;
  // Only keep shop in stack
  while (screenStack.length > 1) screenStack.pop();
  showServiceScreen();
}

// — Service screen —
function showServiceScreen() {
  if (!shopCache) return;
  document.getElementById('service-content').innerHTML = renderServices(shopCache.services);
  goTo('s-service');
  tg.MainButton.hide();
}

function pickService(id, name, duration, price) {
  bk.serviceId = id; bk.serviceName = name;
  bk.serviceDuration = duration; bk.servicePrice = price;
  tg.HapticFeedback.selectionChanged();
  showBarberScreen();
}

function pickServiceFromShop(id, name, duration, price) {
  bk.serviceId = id; bk.serviceName = name;
  bk.serviceDuration = duration; bk.servicePrice = price;
  tg.HapticFeedback.selectionChanged();
  showBarberScreen();
}

// — Barber screen —
function showBarberScreen() {
  if (!shopCache) return;
  document.getElementById('barber-content').innerHTML = renderBarbers(shopCache.barbers);
  goTo('s-barber');
  tg.MainButton.hide();
}

function pickBarberFromShop(id, name, slotDur) {
  bk.barberId = id; bk.barberName = name;
  tg.HapticFeedback.selectionChanged();
  showDatetimeScreen();
}

function pickBarber(id, name, slotDur) {
  bk.barberId = id; bk.barberName = name;
  tg.HapticFeedback.selectionChanged();
  showDatetimeScreen();
}

// — DateTime screen —
function showDatetimeScreen() {
  const today = new Date().toISOString().split('T')[0];
  const inp = document.getElementById('date-input');
  inp.min = today; inp.value = today;
  bk.date = today; bk.time = null;
  goTo('s-datetime');
  tg.MainButton.hide();
  loadSlots(today);
}

document.getElementById('date-input').addEventListener('change', function(){
  bk.date = this.value; bk.time = null;
  tg.MainButton.hide();
  loadSlots(this.value);
});

async function loadSlots(date) {
  const el = document.getElementById('slots-area');
  el.innerHTML = '<div class="loading-wrap"><div class="spinner"></div><div class="spinner-text">BO\'SH VAQTLAR</div></div>';
  try {
    const { slots } = await GET(`/api/slots/?barber_id=${bk.barberId}&date=${date}`);
    if (!slots.length) {
      el.innerHTML = `<div class="empty-wrap">
        <div class="empty-icon" style="font-size:32px;">😔</div>
        <div class="empty-title">Bo'sh vaqt yo'q</div>
        <div class="empty-sub">Boshqa kun tanlang</div></div>`;
      return;
    }
    let html = '<div class="sec-label">Bo\'sh vaqtlar</div><div class="slots-wrap"><div class="slots-grid">';
    slots.forEach(t => {
      html += `<div class="slot-btn" data-time="${t}" onclick="pickSlot(this,'${t}')">${t}</div>`;
    });
    el.innerHTML = html + '</div></div>';
  } catch(e) {
    el.innerHTML = `<div class="empty-wrap"><div class="empty-sub">${esc(e.message)}</div></div>`;
  }
}

function pickSlot(el, time) {
  document.querySelectorAll('.slot-btn').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
  bk.time = time;
  tg.HapticFeedback.selectionChanged();
  tg.MainButton.setText('DAVOM ETISH  →').show().onClick(() => {
    tg.MainButton.offClick();
    showConfirmScreen();
  });
}

// — Confirm screen —
function showConfirmScreen() {
  document.getElementById('confirm-err').style.display = 'none';
  document.getElementById('confirm-summary').innerHTML = `
    <div class="sum-row"><span class="sum-label">Salon</span><span class="sum-val">${esc(bk.shopName)}</span></div>
    <div class="sum-row"><span class="sum-label">Xizmat</span><span class="sum-val">${esc(bk.serviceName)}</span></div>
    <div class="sum-row"><span class="sum-label">Davomiyligi</span><span class="sum-val">${bk.serviceDuration} daqiqa</span></div>
    <div class="sum-row"><span class="sum-label">Usta</span><span class="sum-val">${esc(bk.barberName)}</span></div>
    <div class="sum-row"><span class="sum-label">Sana</span><span class="sum-val">${fmtDate(bk.date)}</span></div>
    <div class="sum-row"><span class="sum-label">Vaqt</span><span class="sum-val">${bk.time}</span></div>
    <div class="sum-row"><span class="sum-label">Narx</span><span class="sum-val sum-price">${fmtP(bk.servicePrice)}</span></div>
  `;
  goTo('s-confirm');
  tg.MainButton.setText('✓  TASDIQLASH').show().onClick(() => {
    tg.MainButton.offClick();
    confirmBooking();
  });
}

async function confirmBooking() {
  tg.MainButton.showProgress(true);
  document.getElementById('confirm-err').style.display = 'none';
  try {
    const d = await POST('/api/bookings/', {
      barber_id:bk.barberId, service_id:bk.serviceId, date:bk.date, time:bk.time
    });
    tg.MainButton.hideProgress();
    tg.HapticFeedback.notificationOccurred('success');
    document.getElementById('success-text').textContent =
      `${d.service} · ${d.date} soat ${d.time}`;
    first('s-success');
    tg.BackButton.hide();
    tg.MainButton.hide();
  } catch(e) {
    tg.MainButton.hideProgress();
    tg.HapticFeedback.notificationOccurred('error');
    const errEl = document.getElementById('confirm-err');
    errEl.textContent = e.message;
    errEl.style.display = 'block';
    tg.MainButton.setText('✓  TASDIQLASH').show().onClick(() => {
      tg.MainButton.offClick(); confirmBooking();
    });
  }
}

// ══════════════════════════════════════════════════════
// My Bookings
// ══════════════════════════════════════════════════════
async function loadMyBookings() {
  goTo('s-my-bookings');
  tg.MainButton.hide();
  const el = document.getElementById('my-bookings-content');
  el.innerHTML = '<div class="loading-wrap"><div class="spinner"></div></div>';
  try {
    const { appointments } = await GET('/api/my-bookings/');
    if (!appointments.length) {
      el.innerHTML = `<div class="empty-wrap">
        <div class="empty-icon">📋</div>
        <div class="empty-title">Bronlar yo'q</div>
        <div class="empty-sub">Hali bron qilmagansiz</div>
      </div>`;
      return;
    }
    const upcoming = appointments.filter(a => a.can_cancel);
    const past = appointments.filter(a => !a.can_cancel);
    let html = '';
    if (upcoming.length) {
      html += '<div class="sec-label">Kelayotgan</div><div class="booking-list">';
      upcoming.forEach(a => { html += bookingCard(a); });
      html += '</div>';
    }
    if (past.length) {
      html += '<div class="sec-label">O\'tganlar</div><div class="booking-list">';
      past.forEach(a => { html += bookingCard(a); });
      html += '</div>';
    }
    el.innerHTML = html;
  } catch(e) {
    el.innerHTML = `<div class="empty-wrap"><div class="empty-title">Xatolik</div>
      <div class="empty-sub">${esc(e.message)}</div></div>`;
  }
}

function bookingCard(a) {
  return `
  <div class="booking-item" onclick="openDetail('${a.id}')">
    <div style="flex:1;min-width:0;">
      <div class="booking-shop">${esc(a.shop_name)}</div>
      <div class="booking-service">${esc(a.service_name)} · ${esc(a.barber_name)}</div>
      <div class="booking-when">
        <i class="fa-regular fa-calendar"></i>${a.date}
        <i class="fa-regular fa-clock" style="margin-left:6px;"></i>${a.time}
      </div>
    </div>
    <span class="badge badge-${a.status}">${a.status_display}</span>
  </div>`;
}

let detailCache = [];
async function openDetail(id) {
  goTo('s-booking-detail');
  tg.MainButton.hide();
  const el = document.getElementById('booking-detail-content');
  el.innerHTML = '<div class="loading-wrap"><div class="spinner"></div></div>';
  try {
    const { appointments } = await GET('/api/my-bookings/');
    detailCache = appointments;
    const a = appointments.find(x => x.id === id);
    if (!a) { el.innerHTML = '<div class="empty-wrap"><div class="empty-title">Topilmadi</div></div>'; return; }
    el.innerHTML = `
      <div class="detail-header">
        <div class="detail-icon"><i class="fa-solid fa-scissors"></i></div>
        <div>
          <div class="detail-shop">${esc(a.shop_name)}</div>
          <div class="detail-service">${esc(a.service_name)}</div>
        </div>
        <span class="badge badge-${a.status}" style="margin-left:auto;">${a.status_display}</span>
      </div>
      <div class="sec-label">Ma'lumotlar</div>
      <div class="summary-box">
        <div class="sum-row"><span class="sum-label">Xizmat</span><span class="sum-val">${esc(a.service_name)}</span></div>
        <div class="sum-row"><span class="sum-label">Usta</span><span class="sum-val">${esc(a.barber_name)}</span></div>
        <div class="sum-row"><span class="sum-label">Sana</span><span class="sum-val">${a.date}</span></div>
        <div class="sum-row"><span class="sum-label">Vaqt</span><span class="sum-val">${a.time} – ${a.end_time}</span></div>
        <div class="sum-row"><span class="sum-label">Narx</span><span class="sum-val sum-price">${fmtP(a.price)}</span></div>
      </div>
      ${a.can_cancel ? `<button class="btn-primary btn-danger" onclick="cancelBooking('${a.id}')">
        <i class="fa-solid fa-xmark"></i> Bronni bekor qilish
      </button>` : ''}
    `;
  } catch(e) {
    el.innerHTML = `<div class="empty-wrap"><div class="empty-sub">${esc(e.message)}</div></div>`;
  }
}

async function cancelBooking(id) {
  const ok = await new Promise(r => tg.showConfirm('Bronni bekor qilmoqchimisiz?', r));
  if (!ok) return;
  try {
    await POST(`/api/bookings/${id}/cancel/`, {});
    tg.HapticFeedback.notificationOccurred('success');
    goBack();
    loadMyBookings();
  } catch(e) {
    tg.showAlert('Xatolik: ' + e.message);
    tg.HapticFeedback.notificationOccurred('error');
  }
}

// ══════════════════════════════════════════════════════
// Helpers
// ══════════════════════════════════════════════════════
function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmtP(p) {
  return parseInt(p).toLocaleString('uz-UZ') + ' so\'m';
}
function fmtDate(iso) {
  const [y,m,d] = iso.split('-');
  return `${d}.${m}.${y}`;
}

// ══════════════════════════════════════════════════════
// Theme Toggle
// ══════════════════════════════════════════════════════
function applyTheme(theme) {
  document.documentElement.setAttribute('data-theme', theme);
  const icon = theme === 'light' ? 'fa-sun' : 'fa-moon';
  document.querySelectorAll('.theme-btn i').forEach(i => {
    i.className = `fa-solid ${icon}`;
  });
  localStorage.setItem('theme', theme);
}

function toggleTheme() {
  const cur = document.documentElement.getAttribute('data-theme') || 'dark';
  applyTheme(cur === 'dark' ? 'light' : 'dark');
  tg.HapticFeedback.selectionChanged();
}

// Saved theme ni yuklash
applyTheme(localStorage.getItem('theme') || 'dark');

// ══════════════════════════════════════════════════════
// Nav Overlay
// ══════════════════════════════════════════════════════
function openNav() {
  document.getElementById('nav-overlay').classList.add('open');
  document.getElementById('nav-backdrop').classList.add('open');
  document.querySelectorAll('.burger').forEach(b => b.classList.add('open'));
  tg.BackButton.hide();
}

function closeNav() {
  document.getElementById('nav-overlay').classList.remove('open');
  document.getElementById('nav-backdrop').classList.remove('open');
  document.querySelectorAll('.burger').forEach(b => b.classList.remove('open'));
  updateNav();
}

function navGo(target) {
  closeNav();
  setTimeout(() => {
    if (target === 'shops') {
      first('s-shops');
    } else if (target === 'my-bookings') {
      loadMyBookings();
    } else if (target === 'barber-dash') {
      loadBarberDash();
    } else if (target === 'become-barber') {
      startBarberReg();
    } else if (target === 'support') {
      goTo('s-support');
      document.getElementById('support-err').style.display = 'none';
      document.getElementById('support-ok').style.display = 'none';
      document.getElementById('support-msg').value = '';
      const btn = document.getElementById('support-send-btn');
      btn.disabled = false;
      btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Yuborish';
    }
  }, 280);
}

// ══════════════════════════════════════════════════════
// Event Bindings
// ══════════════════════════════════════════════════════
document.getElementById('btn-go-mybookings').addEventListener('click', () => { screenStack=[]; loadMyBookings(); });
document.getElementById('btn-close-app').addEventListener('click', () => tg.close());

// Delegate clicks inside service-content (dynamically rendered)
document.getElementById('service-content').addEventListener('click', e => {
  const li = e.target.closest('.price-item[onclick]');
  if (li) { const fn = li.getAttribute('onclick'); if (fn) eval(fn); }
});

// ══════════════════════════════════════════════════════
// Barber Registration State
// ══════════════════════════════════════════════════════
// reg.selectedSvcs: Map<index, {price, duration}> — har bir tanlangan xizmat uchun narx/vaqt
const reg = { spec: 'men', selectedSvcs: new Map(), allPredefined: [], shopId: null, newShopName: '', newShopAddress: '' };

function startBarberReg() {
  ['reg-first-name','reg-last-name','reg-phone','reg-city','reg-bio','reg-exp'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  reg.spec = 'men'; reg.selectedSvcs = new Map(); reg.allPredefined = [];
  reg.shopId = null; reg.newShopName = ''; reg.newShopAddress = '';
  regSalonLogoFile = null;
  pickSpec('men');
  document.getElementById('breg1-err').style.display = 'none';
  goTo('s-breg-1');
  tg.MainButton.hide();
}

function chooseRole(role) {
  tg.HapticFeedback.selectionChanged();
  if (role === 'client') first('s-shops');
  else startBarberReg();
}

function bregStep1Next() {
  const fn   = document.getElementById('reg-first-name').value.trim();
  const city = document.getElementById('reg-city').value.trim();
  const err  = document.getElementById('breg1-err');
  if (!fn || !city) {
    err.textContent = 'Ism va shahar majburiy maydon!';
    err.style.display = 'block';
    tg.HapticFeedback.notificationOccurred('error');
    return;
  }
  err.style.display = 'none';
  tg.HapticFeedback.selectionChanged();
  goTo('s-breg-2');
  tg.MainButton.hide();
}

function bregStep2Next() {
  tg.HapticFeedback.selectionChanged();
  goTo('s-breg-salon');
  loadShopsForReg();
  tg.MainButton.hide();
}

async function loadShopsForReg() {
  const wrap = document.getElementById('salon-list-wrap');
  wrap.innerHTML = '<div class="loading-wrap"><div class="spinner"></div></div>';
  try {
    const { shops } = await GET('/api/shops/');
    const items = shops.map(s => `
      <div class="salon-pick-item" data-id="${s.id}" onclick="pickSalon('${s.id}',null,null,this)">
        <div class="salon-pick-radio"></div>
        <div class="salon-pick-info">
          <div class="salon-pick-name">${esc(s.name)}</div>
          <div class="salon-pick-addr"><i class="fa-solid fa-location-dot" style="font-size:10px;margin-right:4px;"></i>${esc(s.address)}</div>
        </div>
      </div>`).join('');
    wrap.innerHTML = `<div style="background:var(--bg2);border-radius:var(--radius-lg);margin:6px 14px;overflow:hidden;">${items}</div>`;
    // Yangi salon tugmasi
    wrap.insertAdjacentHTML('beforeend', `
      <div class="salon-new-btn" id="salon-new-btn" onclick="pickSalon(null,'new',null,this)">
        <i class="fa-solid fa-plus"></i> Yangi salon qo'shish
      </div>`);
  } catch(e) {
    wrap.innerHTML = `<div class="empty-wrap"><div class="empty-sub">${esc(e.message)}</div></div>`;
  }
}

function pickSalon(id, mode, name, el) {
  // Oldingi tanlovni olib tashlash
  document.querySelectorAll('.salon-pick-item.selected, .salon-new-btn.selected')
    .forEach(x => x.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('breg-salon-err').style.display = 'none';

  if (mode === 'new') {
    reg.shopId = null;
    document.getElementById('new-salon-form').style.display = 'block';
    document.getElementById('new-salon-name').focus();
  } else {
    reg.shopId = id;
    document.getElementById('new-salon-form').style.display = 'none';
  }
  tg.HapticFeedback.selectionChanged();
}

function bregSalonNext() {
  const err = document.getElementById('breg-salon-err');
  const isNew = !!document.querySelector('.salon-new-btn.selected');
  const isExisting = !!document.querySelector('.salon-pick-item.selected');

  if (!isNew && !isExisting) {
    err.textContent = 'Salon tanlang yoki yangi qo\'shing'; err.style.display = 'block';
    tg.HapticFeedback.notificationOccurred('error'); return;
  }

  if (isNew) {
    reg.newShopName = document.getElementById('new-salon-name').value.trim();
    reg.newShopAddress = document.getElementById('new-salon-addr').value.trim();
    if (!reg.newShopName || !reg.newShopAddress) {
      err.textContent = 'Salon nomi va manzilini kiriting'; err.style.display = 'block';
      tg.HapticFeedback.notificationOccurred('error'); return;
    }
  }

  err.style.display = 'none';
  tg.HapticFeedback.selectionChanged();
  goTo('s-breg-3');
  loadPredefinedSvcs();
  tg.MainButton.hide();
}

function pickSpec(val) {
  reg.spec = val;
  ['men','women','all'].forEach(s =>
    document.getElementById('spec-'+s).classList.toggle('selected', s === val)
  );
  tg.HapticFeedback.selectionChanged();
}

async function loadPredefinedSvcs() {
  const el = document.getElementById('predefined-svc-list');
  el.innerHTML = '<div class="loading-wrap"><div class="spinner"></div></div>';
  try {
    const { services } = await GET('/api/barber/predefined-services/');
    reg.allPredefined = services;
    const filtered = services.filter(s => s.group === reg.spec || s.group === 'all');
    el.innerHTML = filtered.map((s, i) => `
      <div class="svc-pick-item" data-i="${i}" onclick="toggleSvc(${i},this)">
        <div class="svc-check"><i class="fa-solid fa-check"></i></div>
        <div class="svc-pick-info">
          <div class="svc-pick-name">${esc(s.name)}</div>
          <div class="svc-pick-meta">${s.duration} daqiqa</div>
        </div>
        <div class="svc-pick-price">${fmtP(s.price)}</div>
      </div>
      <div class="svc-price-row" id="svc-pr-${i}">
        <div style="position:relative;">
          <input class="form-input" id="svc-price-${i}" type="number" min="0" placeholder="Narx" value="${s.price}"
                 oninput="updateSvcData(${i})" style="padding-right:40px;">
          <span style="position:absolute;right:10px;top:50%;transform:translateY(-50%);font-size:11px;color:var(--muted);pointer-events:none;">so'm</span>
        </div>
        <div style="position:relative;">
          <input class="form-input" id="svc-dur-${i}" type="number" min="5" placeholder="30" value="${s.duration}"
                 oninput="updateSvcData(${i})" style="padding-right:32px;">
          <span style="position:absolute;right:8px;top:50%;transform:translateY(-50%);font-size:11px;color:var(--muted);pointer-events:none;">daq</span>
        </div>
      </div>`).join('');
  } catch(e) {
    el.innerHTML = `<div class="empty-wrap"><div class="empty-sub">${esc(e.message)}</div></div>`;
  }
}

function toggleSvc(i, el) {
  el.classList.toggle('selected');
  const prRow = document.getElementById('svc-pr-' + i);
  if (el.classList.contains('selected')) {
    const s = reg.allPredefined[i];
    reg.selectedSvcs.set(i, { price: s.price, duration: s.duration });
    if (prRow) prRow.style.display = 'grid';
  } else {
    reg.selectedSvcs.delete(i);
    if (prRow) prRow.style.display = 'none';
  }
  tg.HapticFeedback.selectionChanged();
}

function updateSvcData(i) {
  if (!reg.selectedSvcs.has(i)) return;
  const price = parseInt(document.getElementById('svc-price-' + i)?.value) || 0;
  const dur   = parseInt(document.getElementById('svc-dur-' + i)?.value) || 30;
  reg.selectedSvcs.set(i, { price, duration: dur });
}

function addCustomSvc() {
  const name  = document.getElementById('csvc-name').value.trim();
  const dur   = parseInt(document.getElementById('csvc-dur').value) || 30;
  const price = parseInt(document.getElementById('csvc-price').value) || 0;
  const err   = document.getElementById('breg3-err');
  if (!name) { err.textContent = 'Xizmat nomini kiriting'; err.style.display='block'; return; }
  if (!price) { err.textContent = 'Narxni kiriting'; err.style.display='block'; return; }
  err.style.display = 'none';
  const i = reg.allPredefined.length;
  reg.allPredefined.push({ name, duration: dur, price, group: 'custom' });
  reg.selectedSvcs.set(i, { price, duration: dur });
  document.getElementById('predefined-svc-list').insertAdjacentHTML('beforeend', `
    <div class="svc-pick-item selected" data-i="${i}" onclick="toggleSvc(${i},this)">
      <div class="svc-check"><i class="fa-solid fa-check"></i></div>
      <div class="svc-pick-info">
        <div class="svc-pick-name">${esc(name)}</div>
        <div class="svc-pick-meta">${dur} daqiqa</div>
      </div>
      <div class="svc-pick-price">${fmtP(price)}</div>
    </div>`);
  document.getElementById('csvc-name').value = '';
  document.getElementById('csvc-dur').value = '';
  document.getElementById('csvc-price').value = '';
  tg.HapticFeedback.notificationOccurred('success');
}

async function submitBarberReg() {
  const btn = document.getElementById('breg3-save-btn');
  const err = document.getElementById('breg3-err');
  err.style.display = 'none';
  if (btn) { btn.disabled = true; btn.innerHTML = '<div class="spinner" style="width:18px;height:18px;margin:0 auto;"></div>'; }

  try {
    const payload = {
      first_name: document.getElementById('reg-first-name').value.trim(),
      last_name:  document.getElementById('reg-last-name').value.trim(),
      phone:      document.getElementById('reg-phone').value.trim(),
      city:       document.getElementById('reg-city').value.trim(),
      bio:        document.getElementById('reg-bio').value.trim(),
      specialization: reg.spec,
      experience_years: parseInt(document.getElementById('reg-exp').value) || 0,
    };
    if (reg.shopId) {
      payload.shop_id = reg.shopId;
    } else {
      payload.shop_name    = reg.newShopName;
      payload.shop_address = reg.newShopAddress;
    }
    await POST('/api/barber/register/', payload);

    // Tanlangan xizmatlarni tahrirlangan narx bilan qo'shish
    const svcs = [...reg.selectedSvcs.entries()].map(([i, data]) => ({
      name: reg.allPredefined[i].name,
      duration: data.duration,
      price: data.price,
    }));
    if (svcs.length) {
      await Promise.all(svcs.map(s => POST('/api/barber/services/', {
        name: s.name, duration: s.duration, price: s.price
      })));
    }

    // Yangi salon uchun logo yuklash
    if (!reg.shopId && regSalonLogoFile) {
      try {
        const fd = new FormData(); fd.append('logo', regSalonLogoFile);
        await fetch('/api/barber/shop/logo/', { method:'POST', headers: authHeadersRaw(), body: fd });
      } catch(_) {}
    }

    tg.HapticFeedback.notificationOccurred('success');
    userProfile = null;
    await loadUserProfile();
    loadBarberDash();
  } catch(e) {
    tg.HapticFeedback.notificationOccurred('error');
    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-check"></i> Saqlash va tugatish'; }
    err.textContent = e.message; err.style.display = 'block';
  }
}

// ══════════════════════════════════════════════════════
// Barber Dashboard
// ══════════════════════════════════════════════════════
async function loadBarberDash() {
  goTo('s-barber-dash');
  tg.MainButton.hide();
  const el = document.getElementById('barber-dash-content');
  el.innerHTML = '<div class="loading-wrap"><div class="spinner"></div></div>';
  try {
    const d = await GET('/api/barber/dashboard/');
    const svcs = await GET('/api/barber/services/');

    const noSvcs = !svcs.services.length;
    const avatarHtml = d.avatar_url
      ? `<img src="${d.avatar_url}" class="avatar-img" alt="avatar">`
      : `<div class="avatar-placeholder"><i class="fa-solid fa-user"></i></div>`;
    el.innerHTML = `
      <div class="barber-profile-card">
        <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px;">
          <div class="avatar-wrap" onclick="showBarberEdit()" style="cursor:pointer;">
            ${avatarHtml}
            <div class="avatar-upload-btn"><i class="fa-solid fa-camera"></i></div>
          </div>
          <div style="flex:1;min-width:0;">
            <div class="bpc-name" style="font-size:17px;">${esc(d.name || 'Barber')}</div>
            <div class="bpc-meta" style="margin-top:4px;">
              <span class="spec-badge">${{men:'Erkaklar',women:'Ayollar',all:'Hammasi'}[d.specialization||'all']}</span>
              ${d.experience_years ? `<span class="bpc-exp">${d.experience_years} yil</span>` : ''}
            </div>
            ${d.shop_name ? `<div style="font-size:11px;color:var(--muted);margin-top:4px;"><i class="fa-solid fa-store" style="font-size:10px;margin-right:3px;"></i>${esc(d.shop_name)}</div>` : ''}
          </div>
        </div>
        <div class="toggle-row">
          <div>
            <div class="toggle-row-label">Bronlash qabul qilish</div>
            <div class="toggle-row-sub" id="accepting-sub">${d.is_accepting ? 'Faol — mijozlar bron qila oladi' : 'O\'chirilgan'}</div>
          </div>
          <label class="toggle">
            <input type="checkbox" id="accepting-chk" ${d.is_accepting ? 'checked' : ''} onchange="toggleAccepting(this)">
            <div class="toggle-track"></div>
          </label>
        </div>
      </div>

      <div class="sec-label">
        Xizmatlarim
        <span style="color:var(--muted);font-size:12px;font-weight:400;text-transform:none;letter-spacing:0;">(${svcs.services.length})</span>
      </div>
      ${noSvcs ? `
        <div class="empty-svc-prompt">
          <i class="fa-solid fa-scissors" style="font-size:28px;color:var(--gold);margin-bottom:8px;"></i>
          <div style="font-weight:600;margin-bottom:4px;">Hali xizmat yo'q</div>
          <div style="font-size:13px;color:var(--muted);">Xizmatlaringizni qo'shing — mijozlar ko'rishi uchun</div>
        </div>` : `
      <ul class="price-list" id="barber-svc-list">
        ${svcs.services.map(s => `
        <li class="price-item">
          <div class="pi-left">
            <div class="pi-name">${esc(s.name)}</div>
            <div class="pi-meta">${s.duration} daq</div>
          </div>
          <div class="pi-dots"></div>
          <div class="pi-price">${fmtP(s.price)}</div>
          <button onclick="deleteSvc('${s.id}')" style="background:none;border:none;color:var(--muted);padding:0 0 0 10px;cursor:pointer;font-size:14px;" title="O'chirish">
            <i class="fa-solid fa-trash-can"></i>
          </button>
        </li>`).join('')}
      </ul>`}
      <button class="btn-primary btn-secondary" onclick="goToAddService()" style="margin-bottom:16px;">
        <i class="fa-solid fa-plus"></i> Xizmat qo'shish
      </button>

      <div class="sec-label">Bugungi statistika</div>
      <div class="dash-stat-row">
        <div class="dash-stat">
          <div class="dash-stat-num">${d.today_count}</div>
          <div class="dash-stat-label">Bugungi bron</div>
        </div>
        <div class="dash-stat">
          <div class="dash-stat-num">${d.upcoming.length}</div>
          <div class="dash-stat-label">Kelayotgan</div>
        </div>
      </div>

      <div class="sec-label">Kelayotgan bronlar</div>
      ${d.upcoming.length ? d.upcoming.map(a => `
        <div class="dash-appt">
          <div class="dash-time-col">
            <div class="dash-time">${a.time}</div>
            <div class="dash-end-time">${a.end_time}</div>
          </div>
          <div style="flex:1">
            <div class="dash-client">${esc(a.client_name)}</div>
            <div class="dash-svc">${esc(a.service_name)}</div>
            <div class="dash-price">${fmtP(a.price)}</div>
          </div>
          <span class="badge badge-${a.status}">${a.status_display}</span>
        </div>`).join('')
      : '<div class="empty-wrap"><div class="empty-sub">Hozircha bron yo\'q</div></div>'}
    `;
  } catch(e) {
    el.innerHTML = `<div class="empty-wrap"><div class="empty-title">Xatolik</div>
      <div class="empty-sub">${esc(e.message)}</div></div>`;
  }
}

async function toggleAccepting(cb) {
  const sub = document.getElementById('accepting-sub');
  try {
    const r = await POST('/api/barber/toggle-accepting/', { is_accepting: cb.checked });
    if (sub) sub.textContent = r.is_accepting ? 'Faol — mijozlar bron qila oladi' : 'O\'chirilgan';
    tg.HapticFeedback.selectionChanged();
  } catch(e) {
    cb.checked = !cb.checked; // revert
    tg.showAlert(e.message);
  }
}

async function deleteSvc(id) {
  const ok = await new Promise(r => tg.showConfirm("Xizmatni o'chirasizmi?", r));
  if (!ok) return;
  try {
    const r = await fetch(`/api/barber/services/${id}/`, {
      method: 'DELETE', headers: { ...authHeaders(), 'X-CSRFToken': csrf() }
    });
    if (!r.ok) throw new Error('Xatolik');
    tg.HapticFeedback.notificationOccurred('success');
    loadBarberDash();
  } catch(e) { tg.showAlert(e.message); }
}

function goToAddService() {
  reg.allPredefined = []; reg.selectedSvcs = new Map();
  // breg3-save-btn ni yashirish — MainButton ishlatamiz
  const saveBtn = document.getElementById('breg3-save-btn');
  if (saveBtn) saveBtn.style.display = 'none';
  goTo('s-breg-3');
  loadPredefinedSvcs();
  tg.MainButton.setText('SAQLASH  ✓').show().onClick(async () => {
    tg.MainButton.offClick();
    tg.MainButton.showProgress(true);
    try {
      const svcs = [...reg.selectedSvcs.entries()].map(([i, data]) => ({
        name: reg.allPredefined[i].name, duration: data.duration, price: data.price,
      }));
      await Promise.all(svcs.map(s => POST('/api/barber/services/', {
        name: s.name, duration: s.duration, price: s.price
      })));
      tg.MainButton.hideProgress();
      if (saveBtn) saveBtn.style.display = '';
      goBack(); loadBarberDash();
    } catch(e) {
      tg.MainButton.hideProgress();
      tg.showAlert(e.message);
    }
  });
}

// ══════════════════════════════════════════════════════
// Image Upload
// ══════════════════════════════════════════════════════
function authHeadersRaw() {
  // multipart uchun Content-Type yo'q (browser o'zi qo'yadi)
  const h = {};
  const initData = tg.initData;
  if (initData) h['Authorization'] = 'tma ' + initData;
  return h;
}

async function uploadImage(file) {
  const fd = new FormData();
  fd.append('file', file);
  const r = await fetch('/api/upload/', {
    method: 'POST',
    headers: authHeadersRaw(),
    body: fd,
  });
  const data = await r.json();
  if (!r.ok) throw new Error(data.error || 'Yuklash xatosi');
  return data.url;
}

// New salon logo during registration
let regSalonLogoFile = null;

function handleNewSalonLogo(input) {
  const file = input.files[0]; if (!file) return;
  regSalonLogoFile = file;
  const pick = document.getElementById('new-salon-logo-pick');
  const reader = new FileReader();
  reader.onload = e => {
    pick.innerHTML = `<img src="${e.target.result}" alt="logo">`;
  };
  reader.readAsDataURL(file);
  tg.HapticFeedback.selectionChanged();
}

// Barber edit screen — avatar
function pickAvatar() {
  document.getElementById('avatar-file-input').click();
}

let editAvatarFile = null;

function handleAvatarPick(input) {
  const file = input.files[0]; if (!file) return;
  editAvatarFile = file;
  const reader = new FileReader();
  reader.onload = e => {
    const img = document.getElementById('edit-avatar-img');
    const ph  = document.getElementById('edit-avatar-placeholder');
    img.src = e.target.result;
    img.style.display = '';
    ph.style.display = 'none';
  };
  reader.readAsDataURL(file);
  tg.HapticFeedback.selectionChanged();
}

// Salon logo in edit screen
let editSalonLogoFile = null;

function pickSalonLogo() {
  document.getElementById('salon-logo-input').click();
}

function handleSalonLogoPick(input) {
  const file = input.files[0]; if (!file) return;
  editSalonLogoFile = file;
  const pick = document.getElementById('edit-salon-logo-pick');
  const reader = new FileReader();
  reader.onload = e => {
    pick.innerHTML = `<img src="${e.target.result}" alt="logo">`;
  };
  reader.readAsDataURL(file);
  tg.HapticFeedback.selectionChanged();
}

// ══════════════════════════════════════════════════════
// Barber Edit Profile
// ══════════════════════════════════════════════════════
let editSpec = 'men';

function editPickSpec(val) {
  editSpec = val;
  ['men','women','all'].forEach(s =>
    document.getElementById('edit-spec-' + s).classList.toggle('selected', s === val)
  );
  tg.HapticFeedback.selectionChanged();
}

async function showBarberEdit() {
  goTo('s-barber-edit');
  editAvatarFile = null; editSalonLogoFile = null;
  try {
    const d = await GET('/api/barber/dashboard/');
    document.getElementById('edit-first-name').value = d.first_name || '';
    document.getElementById('edit-last-name').value  = d.last_name  || '';
    document.getElementById('edit-phone').value      = d.phone      || '';
    document.getElementById('edit-bio').value        = d.bio        || '';
    document.getElementById('edit-exp').value        = d.experience_years || '';
    document.getElementById('edit-shop-name').value  = d.shop_name  || '';
    document.getElementById('edit-shop-addr').value  = d.shop_address || '';
    editSpec = d.specialization || 'men';
    editPickSpec(editSpec);

    // Avatar
    const img = document.getElementById('edit-avatar-img');
    const ph  = document.getElementById('edit-avatar-placeholder');
    if (d.avatar_url) {
      img.src = d.avatar_url; img.style.display = ''; ph.style.display = 'none';
    } else {
      img.style.display = 'none'; ph.style.display = '';
    }
    // Salon logo
    const logoPick = document.getElementById('edit-salon-logo-pick');
    if (d.shop_logo_url) {
      logoPick.innerHTML = `<img src="${d.shop_logo_url}" alt="logo">`;
    } else {
      logoPick.innerHTML = '<i class="fa-solid fa-image"></i><span>Rasm</span>';
    }
  } catch(e) {
    tg.showAlert('Yuklab bo\'lmadi: ' + e.message);
    goBack();
  }
}

async function saveBarberProfile() {
  const btn = document.getElementById('edit-save-btn');
  const err = document.getElementById('edit-profile-err');
  err.style.display = 'none';
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="width:18px;height:18px;margin:0 auto;"></div>';

  try {
    // Avatar yuklash
    if (editAvatarFile) {
      const fd = new FormData(); fd.append('avatar', editAvatarFile);
      const r = await fetch('/api/me/avatar/', { method:'POST', headers: authHeadersRaw(), body: fd });
      if (!r.ok) { const d = await r.json(); throw new Error(d.error || 'Avatar yuklanmadi'); }
    }
    // Salon logo yuklash
    if (editSalonLogoFile) {
      const fd = new FormData(); fd.append('logo', editSalonLogoFile);
      const r = await fetch('/api/barber/shop/logo/', { method:'POST', headers: authHeadersRaw(), body: fd });
      if (!r.ok) { const d = await r.json(); throw new Error(d.error || 'Logo yuklanmadi'); }
    }
    // Matn maydonlarini saqlash
    await POST('/api/barber/profile/update/', {
      first_name: document.getElementById('edit-first-name').value.trim(),
      last_name:  document.getElementById('edit-last-name').value.trim(),
      phone:      document.getElementById('edit-phone').value.trim(),
      bio:        document.getElementById('edit-bio').value.trim(),
      experience_years: parseInt(document.getElementById('edit-exp').value) || 0,
      specialization: editSpec,
      shop_name:    document.getElementById('edit-shop-name').value.trim(),
      shop_address: document.getElementById('edit-shop-addr').value.trim(),
    });

    tg.HapticFeedback.notificationOccurred('success');
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Saqlash';
    goBack();
    loadBarberDash();
  } catch(e) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Saqlash';
    err.textContent = e.message; err.style.display = 'block';
    tg.HapticFeedback.notificationOccurred('error');
  }
}

// ══════════════════════════════════════════════════════
// Support
// ══════════════════════════════════════════════════════
async function submitSupport() {
  const msg = document.getElementById('support-msg').value.trim();
  const err = document.getElementById('support-err');
  const ok  = document.getElementById('support-ok');
  const btn = document.getElementById('support-send-btn');
  err.style.display = 'none'; ok.style.display = 'none';

  if (!msg) {
    err.textContent = 'Xabarni kiriting'; err.style.display = 'block';
    tg.HapticFeedback.notificationOccurred('error'); return;
  }

  btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="width:18px;height:18px;margin:0 auto;"></div>';

  try {
    await POST('/api/support/', { message: msg });
    tg.HapticFeedback.notificationOccurred('success');
    ok.style.display = 'flex';
    document.getElementById('support-msg').value = '';
    btn.innerHTML = '<i class="fa-solid fa-check"></i> Yuborildi';
  } catch(e) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Yuborish';
    err.textContent = e.message; err.style.display = 'block';
    tg.HapticFeedback.notificationOccurred('error');
  }
}

// ══════════════════════════════════════════════════════
// User Profile (cached)
// ══════════════════════════════════════════════════════
let userProfile = null;

async function loadUserProfile() {
  try {
    userProfile = await GET('/api/me/');
    // Nav menu update
    document.getElementById('nav-barber-item').style.display =
      userProfile.is_barber ? '' : 'none';
    document.getElementById('nav-become-barber').style.display =
      userProfile.is_barber ? 'none' : '';
  } catch(e) { /* ignore */ }
}

// ══════════════════════════════════════════════════════
// Bootstrap
// ══════════════════════════════════════════════════════
(async () => {
  await loadShops();
  await loadUserProfile();
  first('s-shops');
})();
</script>
</body>
</html>
