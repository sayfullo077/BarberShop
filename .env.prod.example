# ═══════════════════════════════════════════════════════════
#  BarberShop — PRODUCTION .env
#  Serverda nusxa oling:  cp .env.prod.example .env  va to'ldiring.
# ═══════════════════════════════════════════════════════════

# --- Django ---
# SECRET_KEY generatsiya:  python -c "import secrets;print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE_ME_random_50_chars
DEBUG=False
ALLOWED_HOSTS=barber.it-services.uz
CSRF_TRUSTED_ORIGINS=https://barber.it-services.uz
CORS_ALLOWED_ORIGINS=https://barber.it-services.uz

# --- PostgreSQL (docker'dagi 'db' servisi) ---
DB_NAME=barbershop
DB_USER=barbershop
DB_PASSWORD=CHANGE_ME_strong_password
DB_HOST=db
DB_PORT=5432

# --- Redis (kesh — docker'dagi 'redis' servisi) ---
REDIS_URL=redis://redis:6379/1

# --- Telegram bot (BotFather'dan) ---
# Bot POLLING rejimida ishlaydi ('bot' servisi) — webhook sozlash SHART EMAS.
TELEGRAM_BOT_TOKEN=123456:CHANGE_ME
# Mini-ilova (WebApp) manzili — bot "Bron qilish" tugmasi shuni ochadi. MAJBURIY.
TELEGRAM_WEBAPP_URL=https://barber.it-services.uz/
# Quyidagilar faqat webhook rejimiga o'tsangiz kerak bo'ladi (polling'da e'tiborsiz):
# TELEGRAM_WEBHOOK_URL=https://barber.it-services.uz/webhook/
# TELEGRAM_WEBHOOK_SECRET=

# --- SMS (Eskiz.uz — ixtiyoriy, telefon fallback) ---
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# --- Email (support xabarlari — ixtiyoriy) ---
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@barber.it-services.uz
SUPPORT_EMAIL=

# --- Admin superuser (birinchi ishga tushishda avtomatik yaratiladi) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_admin_password
DJANGO_SUPERUSER_EMAIL=admin@barber.it-services.uz
